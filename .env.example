# Example only. Put real values in HERMES_HOME\.env, never in this repository.
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=replace_with_your_app_secret
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket

# Recommended group behavior for this plugin:
FEISHU_GROUP_POLICY=open
FEISHU_REQUIRE_MENTION=true

# Optional: allow every user in the app's availability scope to use DMs.
# FEISHU_ALLOW_ALL_USERS=true
